{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://myada.site/api/:path*"
    },
    {
      "source": "/attendance/:path*",
      "destination": "https://myada.site/attendance/:path*"
    },
    {
      "source": "/location/:path*",
      "destination": "https://myada.site/location/:path*"
    },
    {
      "source": "/lostfound/:path*",
      "destination": "https://myada.site/lostfound/:path*"
    },
    {
      "source": "/call/:path*",
      "destination": "https://myada.site/call/:path*"
    },
    {
      "source": "/club/:path*",
      "destination": "https://myada.site/club/:path*"
    },
    {
      "source": "/support/:path*",
      "destination": "https://myada.site/support/:path*"
    }
  ]
}
